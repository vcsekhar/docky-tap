    "Docky Settings" : {
      "comment" : "A menu item that, when tapped, shows the Docky settings window.",
      "isCommentAutoGenerated" : true
    },
    "Docky Setup" : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Configuración de Docky"
          }
        }
      }
    },
    "Docky uses a single main window. Choose whether it stays on the primary display or follows the display containing the pointer." : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Docky utiliza una sola ventana principal. Elige si permanece en la pantalla principal o si sigue a la pantalla donde se encuentra el puntero."
          }
        }
      }
    },
    "Docky works best from the Applications folder. Moving it there avoids running from a disk image or temporary location and makes features like Open at Login reliable." : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Docky funciona mejor desde la carpeta Aplicaciones. Moverlo allí evita ejecutarlo desde una imagen de disco o ubicación temporal y hace que funciones como Abrir al iniciar sesión sean fiables."
          }
        }
      }
    },
