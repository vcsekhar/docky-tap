    "Allows tiles to use the enlarged dock sizing behavior when enabled." : {
      "extractionState" : "stale",
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Permite que los íconos usen el comportamiento de tamaño ampliado del dock cuando está activado."
