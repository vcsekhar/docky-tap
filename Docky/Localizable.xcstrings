    "Choose a custom image for any app Docky currently knows about. Custom app icons follow Docky's circle tile clipping when circle tiles are enabled." : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Elige una imagen personalizada para cualquier app que Docky conozca actualmente. Los íconos personalizados siguen el recorte circular de Docky cuando se activan los íconos circulares."
          }
        }
      }
    },
    "Choose an app…" : {
      "extractionState" : "stale",
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Elige una app…"
          }
        }
      }
    },
    "Choose Image..." : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Elegir imagen..."
          }
        }
      }
    },
    "Choose Screenshot / Video…" : {
      "comment" : "A button that allows a user to choose a screenshot or video file to attach to their feedback.",
      "isCommentAutoGenerated" : true
    },
    "Choose the global shortcut that opens Docky's Cmd-Tab-style window switcher." : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Elige el atajo global que abre el conmutador de ventanas estilo Cmd-Tab de Docky."
          }
        }
      }
    },
    "Choose what happens when you click the tile of an app that already has the focus. Clicking idle apps always launches, focuses, or restores their last minimized window." : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Elige qué sucede al hacer clic en el ícono de una app que ya tiene el foco. Al hacer clic en apps inactivas siempre se lanzan, enfocan o restauran su última ventana minimizada."
          }
        }
      }
    },
    "Choose where Docky sits on screen, or mirror the macOS Dock position." : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Elige dónde se ubica Docky en la pantalla o refleja la posición del Dock de macOS."
          }
        }
      }
    },
    "Choose whether Docky appears only in the active Space or joins every Space, including fullscreen auxiliary presentation." : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Elige si Docky aparece solo en el Space activo o si se une a todos los Spaces, incluida la presentación auxiliar en pantalla completa."
          }
        }
      }
    },
    "Choose whether Docky hugs its tiles or stretches across the full screen width or height of the current dock axis." : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Elige si Docky se ajusta al tamaño de sus íconos o si se extiende por todo el ancho o alto de la pantalla en el eje actual del dock."
          }
        }
      }
    },
    "Choose whether Docky shrinks to fit the screen or keeps its size and scrolls when it runs out of room on the current dock axis." : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Elige si Docky se reduce para caber en pantalla o si mantiene su tamaño y se desplaza cuando se queda sin espacio en el eje actual del dock."
          }
        }
      }
    },
    "Choose whether Docky tile chrome keeps the current rounded corners or uses a full circle or capsule clip." : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Elige si el contorno de los íconos de Docky mantiene las esquinas redondeadas actuales o usa un recorte circular o de cápsula."
          }
        }
      }
    },
    "Choose whether running apps use no marker, the classic dot, a pill, or a custom image." : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Elige si las apps en ejecución no usan marcador, el punto clásico, una píldora o una imagen personalizada."
          }
        }
      }
    },
    "Choose whether the dock chrome keeps the current rounded corners or uses a full circle or capsule clip." : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Elige si el contorno del dock mantiene las esquinas redondeadas actuales o usa un recorte circular o de cápsula."
          }
        }
