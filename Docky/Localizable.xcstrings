            "value" : "Funciones de Docky Pro"
          }
        }
      }
    },
    "Docky Pro unlocks switcher preview modes and window context menus inside the switcher." : {
      "extractionState" : "stale",
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Docky Pro desbloquea los modos de vista previa del conmutador y los menús contextuales de ventana dentro del conmutador."
