    },
    "Adds a drop shadow behind every icon-bearing tile. Has no visible effect on spacers and dividers." : {
      "comment" : "A description of the shadow feature in the appearance settings.",
      "isCommentAutoGenerated" : true
    },
    "Adds a visual separator to break up sections in the dock." : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Añade un separador visual para dividir secciones del dock."
          }
