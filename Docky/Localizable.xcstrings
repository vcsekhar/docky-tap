    "(minimized)" : {
      "comment" : "Appends \"(minimized)\" to the window title if the window is currently minimized.",
      "isCommentAutoGenerated" : true
    },
    "%@ • %@" : {
      "comment" : "A subheading that includes the author's name and the version of the widget. The first argument is the author's name. The second argument is the version of the widget.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ • %2$@"
          }
        }
      }
    },
    "%@ s" : {

    },
    "%@ will be removed from disk. It will keep running until you restart Docky." : {
      "comment" : "A message in an alert that appears when a user attempts to install a `.dockywidget` bundle but the bundle is invalid or malformed.",
      "isCommentAutoGenerated" : true
    },
    "%lld" : {
      "comment" : "A stepper that lets the user adjust the number of columns in the Launchpad grid. The value shown is the current number of columns, and the stepper ranges from 1 to 12.",
      "isCommentAutoGenerated" : true
    },
    "%lld pt" : {
      "comment" : "A text label displaying the current value of a slider. The text inside the label is generated by interpolating the slider's value.",
      "isCommentAutoGenerated" : true
    },
    "%lld variants" : {
      "comment" : "A text label showing the number of variants available for a given item in the gallery. The argument is the number of variants for the item.",
      "isCommentAutoGenerated" : true
    },
    "%lld%%" : {
      "comment" : "A text label showing the current padding",
      "isCommentAutoGenerated" : true
    },
    "%lld°" : {
      "comment" : "A temperature value displayed in the weather widget forecast. The argument is the temperature in degrees Celsius, rounded to the nearest whole number.",
      "isCommentAutoGenerated" : true
    },
    "•" : {
      "comment" : "A bullet point used in a calendar event's schedule row.",
      "isCommentAutoGenerated" : true
    },
