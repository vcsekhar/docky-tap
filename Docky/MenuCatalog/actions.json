          }
        },
        {
          "id": "dia.new-window",
          "title": "New Window",
          "kind": "applescript",
          "tileTypes": ["app"],
          "targetApp": "company.thebrowser.dia",
          "permissions": [],
          "inputs": [],
          "script": "tell application id \"company.thebrowser.dia\"\n    make new window\nend tell",
          "destructive": false,
          "requiresFrontmost": false,
          "holdOption": false,
          "when": { "bundleIdentifierEquals": "company.thebrowser.dia" }
        },
        {
          "id": "dia.new-tab",
          "title": "New Tab",
          "kind": "applescript",
          "tileTypes": ["app"],
          "targetApp": "company.thebrowser.dia",
          "permissions": [],
          "inputs": [],
          "script": "tell application id \"company.thebrowser.dia\"\n    tell front window to make new tab\nend tell",
          "destructive": false,
          "requiresFrontmost": false,
          "holdOption": false,
          "when": {
            "all": [
              { "bundleIdentifierEquals": "company.thebrowser.dia" },
              { "flag": "isRunning" }
